icial_Intelligence\\cli\\claudecode\\backup\\restore-claudecode.ps1","content":"#Requires -Version 5.1\n<#\n.SYNOPSIS\n    ULTIMATE Claude Code + OpenCode + Clawdbot Restore v14.0 - NEW PC READY\n.DESCRIPTION\n    Restores EVERYTHING from backup for perfect restoration on a NEW or existing PC.\n    AUTOMATICALLY installs all prerequisites (Node.js, Git, UV, Claude Code, OpenCode, Clawdbot).\n\n    CRITICAL: This script enables COMPLETE restoration on a fresh Windows 11 install.\n\n    NEW IN v14.0 - CLAWDBOT COMPLETE:\n    - Full Clawdbot workspace, configs, memory, cache restoration\n    - All npm global modules restored (including Clawdbot)\n    - Bun package manager restoration\n    - Python/UV full restoration\n    - All 28 restoration sections with v14.0 additions\n    - Package list restoration (npm, pip, uv, winget)\n    - Backward compatible with v12.0-v15.4 backups\n.PARAMETER BackupPath\n    Path to backup directory (optional - auto-detects latest from F:\\backup\\claudecode\\)\n.PARAMETER Force\n    Skip confirmation prompts\n.PARAMETER SkipPrerequisites\n    Skip automatic installation of Node.js, Git, etc.\n.PARAMETER SkipSoftwareInstall\n    Skip installation of Claude Code and OpenCode (restore data only)\n.PARAMETER SkipCredentials\n    Don't restore credentials (security consideration)\n.PARAMETER SkipRegistry\n    Don't restore registry keys\n.PARAMETER SkipEnvVars\n    Don't restore environment variables\n.PARAMETER SkipPackageReinstall\n    Don't reinstall npm/pip packages from backup lists\n.PARAMETER MaxParallelJobs\n    Maximum parallel jobs for fast restoration (default: 16)\n.NOTES\n    Version: 14.0 - CLAWDBOT COMPLETE EDITION\n    Author: Sisyphus AI Agent\n#>\n[CmdletBinding()]\nparam(\n    [string]$BackupPath,\n    [switch]$Force = $false,\n    [switch]$SkipPrerequisites = $false,\n    [switch]$SkipSoftwareInstall = $false,\n    [switch]$SkipCredentials = $false,\n    [switch]$SkipRegistry = $false,\n    [switch]$SkipEnvVars = $false,\n    [switch]$SkipPackageReinstall = $false,\n    [int]$MaxParallelJobs = 16\n)\n\n$ErrorActionPreference = 'Continue'\n$ProgressPreference = 'SilentlyContinue'\n$script:RestoredItems = 0\n$script:InstalledItems = 0\n$script:Errors = @()\n$script:Jobs = @()\n$script:StartTime = Get-Date\n\n#region Helper Functions\nfunction Write-Step {\n    param([string]$Message, [string]$Status = \"INFO\")\n    $color = switch ($Status) {\n        \"SUCCESS\" { \"Green\" }\n        \"WARNING\" { \"Yellow\" }\n        \"ERROR\"   { \"Red\" }\n        \"INSTALL\" { \"Magenta\" }\n        \"FAST\"    { \"Cyan\" }\n        default   { \"Cyan\" }\n    }\n    $timestamp = Get-Date -Format \"HH:mm:ss\"\n    Write-Host \"[$timestamp] \" -NoNewline -ForegroundColor DarkGray\n    Write-Host \"[$Status] \" -NoNewline -ForegroundColor $color\n    Write-Host $Message\n}\n\nfunction Test-IsAdmin {\n    $identity = [Security.Principal.WindowsIdentity]::GetCurrent()\n    $principal = [Security.Principal.WindowsPrincipal]$identity\n    return $principal.IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)\n}\n\nfunction Restore-FastCopy {\n    param(\n        [string]$Source,\n        [string]$Destination,\n        [string]$Description,\n        [switch]$IsFile\n    )\n\n    if (-not (Test-Path $Source)) {\n        return $false\n    }\n\n    try {\n        $destDir = if ($IsFile) { Split-Path $Destination -Parent } else { $Destination }\n        if ($destDir -and -not (Test-Path $destDir)) {\n            New-Item -ItemType Directory -Path $destDir -Force | Out-Null\n        }\n\n        if ($IsFile) {\n            Copy-Item -Path $Source -Destination $Destination -Force -ErrorAction Stop\n        } else {\n            $robocopyArgs = @($Source, $Destination, \"/E\", \"/MT:$MaxParallelJobs\", \"/R:1\", \"/W:1\", \"/NP\", \"/NFL\", \"/NDL\", \"/NJH\", \"/NJS\")\n            $result = & robocopy @robocopyArgs 2>&1\n            if ($LASTEXITCODE -gt 7) {\n                throw \"Robocopy failed with code $LASTEXITCODE\"\n            }\n        }\n\n        $script:RestoredItems++\n        return $true\n    } catch {\n        $script:Errors += \"Failed to restore $Description : $_\"\n        return $false\n    }\n}\n\nfunction Start-ParallelRestore {\n    param([array]$RestoreTasks)\n\n    $jobs = @()\n    $completed = 0\n    $total = $RestoreTasks.Count\n\n    foreach ($task in $RestoreTasks) {\n        while ((Get-Job -State Running -ErrorAction SilentlyContinue).Count -ge $MaxParallelJobs) {\n            Start-Sleep -Milliseconds 100\n            $done = Get-Job -State Completed -ErrorAction SilentlyContinue\n            foreach ($j in $done) {\n                $completed++\n                Receive-Job $j -ErrorAction SilentlyContinue | Out-Null\n                Remove-Job $j -Force -ErrorAction SilentlyContinue\n            }\n        }\n\n        $job = Start-Job -ScriptBlock {\n            param($src, $dst, $desc, $isFile, $mt)\n\n            if (-not (Test-Path $src)) { return @{Success=$false; Desc=$desc; Reason=\"Not found\"} }\n\n            try {\n                $destDir = if ($isFile) { Split-Path $dst -Parent } else { $dst }\n                if ($destDir -and -not (Test-Path $destDir)) {\n                    New-Item -ItemType Directory -Path $destDir -Force | Out-Null\n                }\n\n                if ($isFile) {\n                    Copy-Item -Path $src -Destination $dst -Force -ErrorAction Stop\n                } else {\n                    $robocopyArgs = @($src, $dst, \"/E\", \"/MT:$mt\", \"/R:1\", \"/W:1\", \"/NP\", \"/NFL\", \"/NDL\", \"/NJH\", \"/NJS\")\n                    & robocopy @robocopyArgs 2>&1 | Out-Null\n                }\n                return @{Success=$true; Desc=$desc}\n            } catch {\n                return @{Success=$false; Desc=$desc; Reason=$_.ToString()}\n            }\n        } -ArgumentList $task.Source, $task.Destination, $task.Description, $task.IsFile, $MaxParallelJobs\n\n        $jobs += $job\n    }\n\n    while ((Get-Job -State Running -ErrorAction SilentlyContinue).Count -gt 0) {\n        Start-Sleep -Milliseconds 100\n    }\n\n    foreach ($job in (Get-Job -ErrorAction SilentlyContinue)) {\n        $result = Receive-Job $job -ErrorAction SilentlyContinue\n        if ($result.Success) {\n            $script:RestoredItems++\n            Write-Step \"  -> $($result.Desc)\" \"SUCCESS\"\n        } elseif ($result.Reason -ne \"Not found\") {\n            $script:Errors += \"Failed: $($result.Desc) - $($result.Reason)\"\n            Write-Step \"  -> Failed: $($result.Desc)\" \"ERROR\"\n        }\n        Remove-Job $job -Force -ErrorAction SilentlyContinue\n    }\n}\n\nfunction Import-RegistryFile {\n    param([string]$RegFile, [string]$Description)\n    if (Test-Path $RegFile) {\n        try {\n            reg import $RegFile 2>$null\n            Write-Step \"  -> Registry: $Description\" \"SUCCESS\"\n            return $true\n        } catch {\n            Write-Step \"  -> Failed: Registry $Description - $_\" \"ERROR\"\n            return $false\n        }\n    }\n    return $false\n}\n\nfunction Install-WithWinget {\n    param([string]$PackageId, [string]$Name)\n\n    Write-Step \"  -> Installing $Name via winget...\" \"INSTALL\"\n    try {\n        $result = winget install --id $PackageId --accept-package-agreements --accept-source-agreements 2>&1\n        if ($LASTEXITCODE -eq 0 -or $result -match \"already installed\") {\n            Write-Step \"  -> $Name installed successfully\" \"SUCCESS\"\n            $script:InstalledItems++\n            return $true\n        } else {\n            Write-Step \"  -> Failed to install $Name\" \"ERROR\"\n            return $false\n        }\n    } catch {\n        Write-Step \"  -> Failed: $Name - $_\" \"ERROR\"\n        return $false\n    }\n}\n\nfunction Refresh-Path {\n    $env:Path = [System.Environment]::GetEnvironmentVariable(\"Path\", \"Machine\") + \";\" +\n                [System.Environment]::GetEnvironmentVariable(\"Path\", \"User\")\n}\n#endregion\n\n#region Auto-detect Backup\n$BackupRoot = \"F:\\backup\\claudecode\"\nif (-not $BackupPath) {\n    $latestBackup = Get-ChildItem -Path $BackupRoot -Directory -ErrorAction SilentlyContinue |\n                    Where-Object { $_.Name -match \"^backup_\\d{4}_\\d{2}_\\d{2}\" } |\n                    Sort-Object { $_.LastWriteTime } -Descending |\n                    Select-Object -First 1\n    if ($latestBackup) {\n        $BackupPath = $latestBackup.FullName\n    } else {\n        Write-Host \"\"\n        Write-Host \"ERROR: No backups found in $BackupRoot\" -ForegroundColor Red\n        Write-Host \"Please specify -BackupPath parameter manually.\" -ForegroundColor Yellow\n        exit 1\n    }\n}\n\nif (-not (Test-Path $BackupPath)) {\n    Write-Host \"ERROR: Backup path not found: $BackupPath\" -ForegroundColor Red\n    exit 1\n}\n#endregion\n\n#region Banner and Metadata\nWrite-Host \"\"\nWrite-Host \"=\" * 75 -ForegroundColor Cyan\nWrite-Host \"  CLAUDE CODE + OPENCODE + CLAWDBOT ULTIMATE RESTORE v14.0\" -ForegroundColor White\nWrite-Host \"  CLI BINARY | AUTH | CLAWDBOT | 28 SECTIONS | 100% RESTORATION\" -ForegroundColor Yellow\nWrite-Host \"=\" * 75 -ForegroundColor Cyan\nWrite-Host \"Timestamp: $(Get-Date -Format 'yyyy-MM-dd HH:mm:ss')\"\nWrite-Host \"Restoring from: $BackupPath\"\nWrite-Host \"Parallel jobs: $MaxParallelJobs (robocopy MT:$MaxParallelJobs)\"\n\n$metadataPath = Join-Path $BackupPath \"METADATA.json\"\nif (-not (Test-Path $metadataPath)) {\n    $metadataPath = Join-Path $BackupPath \"BACKUP-METADATA.json\"\n}\nif (Test-Path $metadataPath) {\n    $metadata = Get-Content $metadataPath -Raw | ConvertFrom-Json\n    Write-Host \"\"\n    Write-Host \"  Backup Version: $($metadata.Version)\"\n    Write-Host \"  Backup Date: $($metadata.Timestamp)\"\n    Write-Host \"  Source Computer: $($metadata.Computer)\"\n    Write-Host \"  Items: $($metadata.TotalFiles) | Size: $($metadata.TotalSizeMB) MB\"\n}\nWrite-Host \"=\" * 75 -ForegroundColor Cyan\nWrite-Host \"\"\n\n$HOME_DIR = $env:USERPROFILE\n$APPDATA = $env:APPDATA\n$LOCALAPPDATA = $env:LOCALAPPDATA\n\n$isNewPC = $null -eq (Get-Command claude -ErrorAction SilentlyContinue)\nif ($isNewPC) {\n    Write-Host \"[NEW PC DETECTED] Claude Code not found - will install prerequisites\" -ForegroundColor Yellow\n    Write-Host \"\"\n}\n#endregion\n\n#region 1. PREREQUISITES INSTALLATION (New PC)\nif (-not $SkipPrerequisites -and $isNewPC) {\n    Write-Step \"[1/28] Installing PREREQUISITES for New PC...\" \"INFO\"\n\n    $hasWinget = $null -ne (Get-Command winget -ErrorAction SilentlyContinue)\n\n    if (-not $hasWinget) {\n        Write-Step \"  -> winget not found - manual installation required\" \"WARNING\"\n        Write-Host \"\"\n        Write-Host \"  Please install manually:\" -ForegroundColor Yellow\n        Write-Host \"    - Node.js LTS: https://nodejs.org/\" -ForegroundColor White\n        Write-Host \"    - Git: https://git-scm.com/\" -ForegroundColor White\n        Write-Host \"\"\n    } else {\n        if (-not (Get-Command node -ErrorAction SilentlyContinue)) {\n            Install-WithWinget \"OpenJS.NodeJS.LTS\" \"Node.js LTS\"\n            Refresh-Path\n        } else {\n            Write-Step \"  -> Node.js already installed\" \"SUCCESS\"\n        }\n\n        if (-not (Get-Command git -ErrorAction SilentlyContinue)) {\n            Install-WithWinget \"Git.Git\" \"Git\"\n            Refresh-Path\n        } else {\n            Write-Step \"  -> Git already installed\" \"SUCCESS\"\n        }\n\n        if (-not (Get-Command python -ErrorAction SilentlyContinue)) {\n            Install-WithWinget \"Python.Python.3.11\" \"Python 3.11\"\n            Refresh-Path\n        } else {\n            Write-Step \"  -> Python already installed\" \"SUCCESS\"\n        }\n    }\n} else {\n    Write-Step \"[1/28] Skipping prerequisites (existing PC or --SkipPrerequisites)\" \"INFO\"\n}\n#endregion\n\n#region 2. INSTALL CLAUDE CODE & OPENCODE & CLAWDBOT\nif (-not $SkipSoftwareInstall) {\n    Write-Step \"[2/28] Installing Claude Code, OpenCode & Clawdbot...\" \"INFO\"\n\n    if (-not (Get-Command claude -ErrorAction SilentlyContinue)) {\n        if (Get-Command npm -ErrorAction SilentlyContinue) {\n            Write-Step \"  -> Installing Claude Code (@anthropic-ai/claude-code) via npm...\" \"INSTALL\"\n            try {\n                $wrongPackage = npm list -g claude-code 2>$null | Select-String -Pattern \"claude-code@1\"\n                if ($wrongPackage) {\n                    Write-Step \"  -> Removing incorrect 'claude-code' package...\" \"WARNING\"\n                    npm uninstall -g claude-code 2>&1 | Out-Null\n                }\n\n                npm install -g @anthropic-ai/claude-code 2>&1 | Out-Null\n                Refresh-Path\n                if (Get-Command claude -ErrorAction SilentlyContinue) {\n                    Write-Step \"  -> Claude Code installed successfully\" \"SUCCESS\"\n                    $script:InstalledItems++\n                } else {\n                    Write-Step \"  -> Claude Code installation may need PATH refresh\" \"WARNING\"\n                }\n            } catch {\n                Write-Step \"  -> Failed to install Claude Code: $_\" \"ERROR\"\n            }\n        } else {\n            Write-Step \"  -> npm not available - install Node.js first\" \"ERROR\"\n        }\n    } else {\n        Write-Step \"  -> Claude Code already installed\" \"SUCCESS\"\n    }\n\n    if (-not (Get-Command opencode -ErrorAction SilentlyContinue)) {\n        Write-Step \"  -> Installing OpenCode (opencode-ai) via npm...\" \"INSTALL\"\n\n        if (Get-Command npm -ErrorAction SilentlyContinue) {\n            try {\n                npm install -g opencode-ai 2>&1 | Out-Null\n                Refresh-Path\n                if (Get-Command opencode -ErrorAction SilentlyContinue) {\n                    Write-Step \"  -> OpenCode installed successfully via npm\" \"SUCCESS\"\n                    $script:InstalledItems++\n                } else {\n                    $installCmd = \"irm https://opencode.ai/install.ps1 | iex\"\n                    Invoke-Expression $installCmd 2>&1 | Out-Null\n                    Refresh-Path\n                }\n            } catch {\n                Write-Step \"  -> npm install failed, trying PowerShell installer...\" \"WARNING\"\n                try {\n                    $installCmd = \"irm https://opencode.ai/install.ps1 | iex\"\n                    Invoke-Expression $installCmd 2>&1 | Out-Null\n                    Refresh-Path\n                } catch {\n                    Write-Step \"  -> Failed to auto-install OpenCode: $_\" \"WARNING\"\n                }\n            }\n        }\n    } else {\n        Write-Step \"  -> OpenCode already installed\" \"SUCCESS\"\n    }\n\n    # Install Clawdbot\n    if (-not (Get-Command clawdbot -ErrorAction SilentlyContinue)) {\n        Write-Step \"  -> Installing Clawdbot via npm...\" \"INSTALL\"\n        if (Get-Command npm -ErrorAction SilentlyContinue) {\n            try {\n                npm install -g clawdbot 2>&1 | Out-Null\n                Refresh-Path\n                if (Get-Command clawdbot -ErrorAction SilentlyContinue) {\n                    Write-Step \"  -> Clawdbot installed successfully\" \"SUCCESS\"\n                    $script:InstalledItems++\n                } else {\n                    Write-Step \"  -> Clawdbot installation may need PATH refresh\" \"WARNING\"\n                }\n            } catch {\n                Write-Step \"  -> Failed to install Clawdbot: $_\" \"WARNING\"\n            }\n        }\n    } else {\n        Write-Step \"  -> Clawdbot already installed\" \"SUCCESS\"\n    }\n\n    # Install UV (Python package manager)\n    if (-not (Get-Command uv -ErrorAction SilentlyContinue)) {\n        Write-Step \"  -> Installing UV (Python package manager)...\" \"INSTALL\"\n        try {\n            $uvInstall = \"irm https://astral.sh/uv/install.ps1 | iex\"\n            Invoke-Expression $uvInstall 2>&1 | Out-Null\n            Refresh-Path\n            if (Get-Command uv -ErrorAction SilentlyContinue) {\n                Write-Step \"  -> UV installed successfully\" \"SUCCESS\"\n                $script:InstalledItems++\n            }\n        } catch {\n            Write-Step \"  -> UV installation optional - skipping\" \"WARNING\"\n        }\n    } else {\n        Write-Step \"  -> UV already installed\" \"SUCCESS\"\n    }\n\n    # Install Bun\n    if (-not (Get-Command bun -ErrorAction SilentlyContinue)) {\n        Write-Step \"  -> Installing Bun...\" \"INSTALL\"\n        try {\n            $bunInstall = \"irm bun.sh/install.ps1 | iex\"\n            Invoke-Expression $bunInstall 2>&1 | Out-Null\n            Refresh-Path\n            if (Get-Command bun -ErrorAction SilentlyContinue) {\n                Write-Step \"  -> Bun installed successfully\" \"SUCCESS\"\n                $script:InstalledItems++\n            }\n        } catch {\n            Write-Step \"  -> Bun installation optional - skipping\" \"WARNING\"\n        }\n    } else {\n        Write-Step \"  -> Bun already installed\" \"SUCCESS\"\n    }\n} else {\n    Write-Step \"[2/28] Skipping software installation (--SkipSoftwareInstall)\" \"INFO\"\n}\n#endregion\n\n#region 3. CLAUDE CODE CLI BINARY (CRITICAL!)\nWrite-Step \"[3/28] Restoring CLAUDE CODE CLI BINARY (CRITICAL!)...\" \"FAST\"\n\n# v15.x backup structure\n$cliBinaryBackup = \"$BackupPath\\cli\\claude-code\"\nif (-not (Test-Path $cliBinaryBackup)) {\n    # v13.x backup structure\n    $cliBinaryBackup = \"$BackupPath\\cli-binary\\claude-code\"\n}\nif (Test-Path $cliBinaryBackup) {\n    $claudeCodeDest = \"$APPDATA\\Claude\\claude-code\"\n    if (Restore-FastCopy $cliBinaryBackup $claudeCodeDest \"Claude Code CLI binary\") {\n        Write-Step \"  -> Claude Code CLI binary restored!\" \"SUCCESS\"\n    }\n} else {\n    Write-Step \"  -> CLI binary not in backup (will use npm install)\" \"WARNING\"\n}\n\n# Restore .local directory (contains bin, share, etc.)\n$dotLocalBackup = \"$BackupPath\\core\\dot-local\"\nif (-not (Test-Path $dotLocalBackup)) {\n    $dotLocalBackup = \"$BackupPath\\cli-binary\\dot-local\"\n}\nif (Test-Path $dotLocalBackup) {\n    $dotLocalDest = \"$HOME_DIR\\.local\"\n    if (Restore-FastCopy $dotLocalBackup $dotLocalDest \".local directory (full)\") {\n        Write-Step \"  -> .local directory restored!\" \"SUCCESS\"\n    }\n    \n    $localBinDest = \"$HOME_DIR\\.local\\bin\"\n    $userPath = [Environment]::GetEnvironmentVariable(\"Path\", \"User\")\n    if ($userPath -notmatch [regex]::Escape($localBinDest)) {\n        Write-Step \"  -> Adding .local\\bin to PATH...\" \"INSTALL\"\n        $newPath = \"$localBinDest;$userPath\"\n        [Environment]::SetEnvironmentVariable(\"Path\", $newPath, \"User\")\n        $env:Path = \"$localBinDest;$env:Path\"\n        Write-Step \"  -> PATH updated with .local\\bin\" \"SUCCESS\"\n    } else {\n        Write-Step \"  -> .local\\bin already in PATH\" \"SUCCESS\"\n    }\n}\n\n# Legacy: .local\\bin directory only\n$localBinBackup = \"$BackupPath\\cli-binary\\local-bin\"\nif (Test-Path $localBinBackup) {\n    $localBinDest = \"$HOME_DIR\\.local\\bin\"\n    if (-not (Test-Path $localBinDest)) {\n        New-Item -ItemType Directory -Path $localBinDest -Force | Out-Null\n    }\n    if (Restore-FastCopy $localBinBackup $localBinDest \".local\\bin (claude.exe, uv.exe)\") {\n        Write-Step \"  -> .local\\bin restored!\" \"SUCCESS\"\n    }\n}\n\nRefresh-Path\n\n$claudeExe = Get-Command claude -ErrorAction SilentlyContinue\nif ($claudeExe) {\n    Write-Step \"  -> Claude CLI verified: $($claudeExe.Source)\" \"SUCCESS\"\n} else {\n    Write-Step \"  -> Claude CLI not found after restore - may need terminal restart\" \"WARNING\"\n}\n#endregion\n\n#region 4. GIT CONFIGURATION & SSH KEYS\nWrite-Step \"[4/28] Restoring GIT CONFIG & SSH KEYS (CRITICAL!)...\" \"FAST\"\n\n# v15.x paths\n$gitBackup = \"$BackupPath\\git\"\nif (Restore-FastCopy \"$gitBackup\\gitconfig\" \"$HOME_DIR\\.gitconfig\" \"Git config (.gitconfig)\" -IsFile) {\n    Write-Step \"  -> .gitconfig\" \"SUCCESS\"\n}\nif (Restore-FastCopy \"$gitBackup\\git-credentials\" \"$HOME_DIR\\.git-credentials\" \"Git credentials\" -IsFile) {\n    Write-Step \"  -> .git-credentials\" \"SUCCESS\"\n}\n\n# SSH Keys\nif (Test-Path \"$gitBackup\\ssh\") {\n    Write-Step \"  -> Restoring SSH keys...\" \"FAST\"\n    $sshDest = \"$HOME_DIR\\.ssh\"\n    if (-not (Test-Path $sshDest)) {\n        New-Item -ItemType Directory -Path $sshDest -Force | Out-Null\n    }\n    Restore-FastCopy \"$gitBackup\\ssh\" $sshDest \"SSH keys\"\n\n    $sshFiles = Get-ChildItem $sshDest -File -ErrorAction SilentlyContinue\n    foreach ($file in $sshFiles) {\n        if ($file.Name -notmatch \"\\.pub$\" -and $file.Name -ne \"known_hosts\" -and $file.Name -ne \"config\") {\n            try {\n                $acl = Get-Acl $file.FullName\n                $acl.SetAccessRuleProtection($true, $false)\n                $rule = New-Object System.Security.AccessControl.FileSystemAccessRule($env:USERNAME, \"FullControl\", \"Allow\")\n                $acl.SetAccessRule($rule)\n                Set-Acl $file.FullName $acl -ErrorAction SilentlyContinue\n            } catch {}\n        }\n    }\n    Write-Step \"  -> SSH keys restored with permissions\" \"SUCCESS\"\n}\n\n# GPG Keys\nif (Test-Path \"$gitBackup\\gnupg\") {\n    $gpgHome = \"$HOME_DIR\\.gnupg\"\n    Restore-FastCopy \"$gitBackup\\gnupg\" $gpgHome \"GPG keys\"\n    Write-Step \"  -> GPG keys\" \"SUCCESS\"\n}\n\n# GitHub CLI config\nif (Test-Path \"$gitBackup\\gh-cli\") {\n    Restore-FastCopy \"$gitBackup\\gh-cli\" \"$HOME_DIR\\.config\\gh\" \"GitHub CLI config\"\n    Write-Step \"  -> GitHub CLI config\" \"SUCCESS\"\n}\n\n# Legacy paths (v13.x)\nif (Restore-FastCopy \"$BackupPath\\git\\.gitconfig\" \"$HOME_DIR\\.gitconfig\" \"Git config\" -IsFile) {}\nif (Restore-FastCopy \"$BackupPath\\git\\.gitignore_global\" \"$HOME_DIR\\.gitignore_global\" \"Global gitignore\" -IsFile) {}\nif (Restore-FastCopy \"$BackupPath\\git\\.git-credentials\" \"$HOME_DIR\\.git-credentials\" \"Git credentials\" -IsFile) {}\nif (Test-Path \"$BackupPath\\ssh\") {\n    Restore-FastCopy \"$BackupPath\\ssh\" \"$HOME_DIR\\.ssh\" \"SSH keys (legacy)\"\n}\nif (Test-Path \"$BackupPath\\gpg\") {\n    Restore-FastCopy \"$BackupPath\\gpg\" \"$HOME_DIR\\.gnupg\" \"GPG keys (legacy)\"\n}\n#endregion\n\n#region 5. CORE CLAUDE CODE FILES\nWrite-Step \"[5/28] Restoring CORE Claude Code files (TURBO)...\" \"FAST\"\n\n$coreTasks = @(\n    @{Source=\"$BackupPath\\core\\claude.json\"; Destination=\"$HOME_DIR\\.claude.json\"; Description=\".claude.json\"; IsFile=$true},\n    @{Source=\"$BackupPath\\core\\claude.json.backup\"; Destination=\"$HOME_DIR\\.claude.json.backup\"; Description=\".claude.json.backup\"; IsFile=$true},\n    @{Source=\"$BackupPath\\core\\claude-home\"; Destination=\"$HOME_DIR\\.claude\"; Description=\".claude directory\"; IsFile=$false}\n)\n\nforeach ($task in $coreTasks) {\n    if (Restore-FastCopy $task.Source $task.Destination $task.Description -IsFile:$task.IsFile) {\n        Write-Step \"  -> $($task.Description)\" \"SUCCESS\"\n    }\n}\n#endregion\n\n#region 6. CREDENTIALS & AUTH (CRITICAL!)\nif (-not $SkipCredentials) {\n    Write-Step \"[6/28] Restoring CREDENTIALS & AUTH (CRITICAL!)...\" \"INFO\"\n\n    $credTasks = @(\n        # v15.x paths\n        @{Source=\"$BackupPath\\creds\\credentials.json\"; Destination=\"$HOME_DIR\\.claude\\.credentials.json\"; Description=\"Claude OAuth\"; IsFile=$true},\n        @{Source=\"$BackupPath\\creds\\creds-alt.json\"; Destination=\"$HOME_DIR\\.claude\\credentials.json\"; Description=\"Claude credentials alt\"; IsFile=$true},\n        @{Source=\"$BackupPath\\creds\\opencode-auth.json\"; Destination=\"$HOME_DIR\\.local\\share\\opencode\\auth.json\"; Description=\"OpenCode auth.json\"; IsFile=$true},\n        # v13.x paths\n        @{Source=\"$BackupPath\\credentials\\claude-credentials.json\"; Destination=\"$HOME_DIR\\.claude\\.credentials.json\"; Description=\"Claude OAuth (legacy)\"; IsFile=$true},\n        @{Source=\"$BackupPath\\credentials\\claude-credentials-alt.json\"; Destination=\"$HOME_DIR\\.claude\\credentials.json\"; Description=\"Claude credentials alt (legacy)\"; IsFile=$true},\n        @{Source=\"$BackupPath\\credentials\\opencode-auth.json\"; Destination=\"$HOME_DIR\\.local\\share\\opencode\\auth.json\"; Description=\"OpenCode auth.json (legacy)\"; IsFile=$true},\n        @{Source=\"$BackupPath\\credentials\\opencode-mcp-auth.json\"; Destination=\"$HOME_DIR\\.local\\share\\opencode\\mcp-auth.json\"; Description=\"OpenCode MCP auth\"; IsFile=$true},\n        @{Source=\"$BackupPath\\credentials\\anthropic-credentials.json\"; Destination=\"$HOME_DIR\\.anthropic\\credentials.json\"; Description=\"Anthropic credentials\"; IsFile=$true},\n        @{Source=\"$BackupPath\\credentials\\settings-local.json\"; Destination=\"$HOME_DIR\\.claude\\settings.local.json\"; Description=\"settings.local.json\"; IsFile=$true}\n    )\n\n    foreach ($task in $credTasks) {\n        if (Restore-FastCopy $task.Source $task.Destination $task.Description -IsFile:$task.IsFile) {\n            Write-Step \"  -> $($task.Description)\" \"SUCCESS\"\n        }\n    }\n\n    if (Test-Path \"$BackupPath\\credentials\\env-files\") {\n        Get-ChildItem \"$BackupPath\\credentials\\env-files\" -File -ErrorAction SilentlyContinue | ForEach-Object {\n            if (Restore-FastCopy $_.FullName \"$HOME_DIR\\$($_.Name)\" \"ENV: $($_.Name)\" -IsFile) {\n                Write-Step \"  -> ENV: $($_.Name)\" \"SUCCESS\"\n            }\n        }\n    }\n} else {\n    Write-Step \"[6/28] Skipping CREDENTIALS (--SkipCredentials)\" \"WARNING\"\n}\n#endregion\n\n#region 7. SESSIONS & CONVERSATION HISTORY\nWrite-Step \"[7/28] Restoring SESSIONS & CONVERSATIONS (TURBO)...\" \"FAST\"\n\n$sessionTasks = @(\n    @{Source=\"$BackupPath\\sessions\\projects\"; Destination=\"$HOME_DIR\\.claude\\projects\"; Description=\".claude/projects\"; IsFile=$false},\n    @{Source=\"$BackupPath\\sessions\\sessions\"; Destination=\"$HOME_DIR\\.claude\\sessions\"; Description=\".claude/sessions\"; IsFile=$false},\n    @{Source=\"$BackupPath\\sessions\\history.jsonl\"; Destination=\"$HOME_DIR\\.claude\\history.jsonl\"; Description=\"history.jsonl\"; IsFile=$true},\n    # v13.x paths\n    @{Source=\"$BackupPath\\sessions\\config-claude-projects\"; Destination=\"$HOME_DIR\\.config\\claude\\projects\"; Description=\".config/claude/projects\"; IsFile=$false},\n    @{Source=\"$BackupPath\\sessions\\claude-projects\"; Destination=\"$HOME_DIR\\.claude\\projects\"; Description=\".claude/projects (legacy)\"; IsFile=$false},\n    @{Source=\"$BackupPath\\sessions\\claude-sessions\"; Destination=\"$HOME_DIR\\.claude\\sessions\"; Description=\".claude/sessions (legacy)\"; IsFile=$false},\n    @{Source=\"$BackupPath\\sessions\\runtime\\local\"; Destination=\"$HOME_DIR\\.claude\\local\"; Description=\".claude/local\"; IsFile=$false},\n    @{Source=\"$BackupPath\\sessions\\runtime\\statsig\"; Destination=\"$HOME_DIR\\.claude\\statsig\"; Description=\".claude/statsig\"; IsFile=$false},\n    @{Source=\"$BackupPath\\sessions\\runtime\\todos\"; Destination=\"$HOME_DIR\\.claude\\todos\"; Description=\".claude/todos\"; IsFile=$false},\n    @{Source=\"$BackupPath\\sessions\\runtime\\cache\"; Destination=\"$HOME_DIR\\.claude\\cache\"; Description=\".claude/cache\"; IsFile=$false}\n)\n\nforeach ($task in $sessionTasks) {\n    if (Restore-FastCopy $task.Source $task.Destination $task.Description -IsFile:$task.IsFile) {\n        Write-Step \"  -> $($task.Description)\" \"SUCCESS\"\n    }\n}\n\n# SQLite databases\nforeach ($dbPath in @(\"$BackupPath\\sessions\\databases\", \"$BackupPath\\claude\\db\")) {\n    if (Test-Path $dbPath) {\n        $dbDest = \"$HOME_DIR\\.claude\"\n        if (-not (Test-Path $dbDest)) {\n            New-Item -ItemType Directory -Path $dbDest -Force | Out-Null\n        }\n        Get-ChildItem $dbPath -File -Filter \"*.db\" -ErrorAction SilentlyContinue | ForEach-Object {\n            if (Restore-FastCopy $_.FullName \"$dbDest\\$($_.Name)\" \"Database: $($_.Name)\" -IsFile) {\n                Write-Step \"  -> Database: $($_.Name)\" \"SUCCESS\"\n            }\n        }\n    }\n}\n#endregion\n\n#region 8. .CLAUDE SUBDIRECTORIES (v15.x structure)\nWrite-Step \"[8/28] Restoring .CLAUDE subdirectories...\" \"FAST\"\n\n$claudeSubdirs = @(\n    @{Source=\"$BackupPath\\claude\\beads\"; Destination=\"$HOME_DIR\\.claude\\.beads\"; Description=\".claude/.beads\"},\n    @{Source=\"$BackupPath\\claude\\sisyphus\"; Destination=\"$HOME_DIR\\.claude\\.sisyphus\"; Description=\".claude/.sisyphus\"},\n    @{Source=\"$BackupPath\\claude\\hooks\"; Destination=\"$HOME_DIR\\.claude\\hooks\"; Description=\".claude/hooks\"},\n    @{Source=\"$BackupPath\\claude\\rules\"; Destination=\"$HOME_DIR\\.claude\\rules\"; Description=\".claude/rules\"},\n    @{Source=\"$BackupPath\\claude\\commands\"; Destination=\"$HOME_DIR\\.claude\\commands\"; Description=\".claude/commands\"},\n    @{Source=\"$BackupPath\\claude\\transcripts\"; Destination=\"$HOME_DIR\\.claude\\transcripts\"; Description=\".claude/transcripts\"}\n)\n\nforeach ($task in $claudeSubdirs) {\n    if (Restore-FastCopy $task.Source $task.Destination $task.Description) {\n        Write-Step \"  -> $($task.Description)\" \"SUCCESS\"\n    }\n}\n\n# v13.x: claude-dirs backup\nif (Test-Path \"$BackupPath\\claude-dirs\") {\n    $claudeDirsPath = \"$BackupPath\\claude-dirs\"\n    $claudeSubdirsOld = Get-ChildItem $claudeDirsPath -Directory -ErrorAction SilentlyContinue\n    foreach ($subdir in $claudeSubdirsOld) {\n        $destPath = \"$HOME_DIR\\.claude\\$($subdir.Name)\"\n        if ($subdir.Name -match '^\\.' -or $subdir.Name -eq 'beads' -or $subdir.Name -eq 'sisyphus') {\n            $destPath = \"$HOME_DIR\\.claude\\.$($subdir.Name)\"\n        }\n        if (Restore-FastCopy $subdir.FullName $destPath \".claude/$($subdir.Name)\") {\n            Write-Step \"    -> .claude/$($subdir.Name)\" \"SUCCESS\"\n        }\n    }\n}\n\n# claude-json files\nforeach ($jsonPath in @(\"$BackupPath\\claude-json\", \"$BackupPath\\claude-files\\json\")) {\n    if (Test-Path $jsonPath) {\n        $jsonFiles = Get-ChildItem $jsonPath -File -Filter \"*.json\" -ErrorAction SilentlyContinue\n        foreach ($jsonFile in $jsonFiles) {\n            if (Restore-FastCopy $jsonFile.FullName \"$HOME_DIR\\.claude\\$($jsonFile.Name)\" \".claude/$($jsonFile.Name)\" -IsFile) {\n                Write-Step \"  -> .claude/$($jsonFile.Name)\" \"SUCCESS\"\n            }\n        }\n    }\n}\n#endregion\n\n#region 9. PROJECT-LEVEL .CLAUDE DIRECTORIES\nWrite-Step \"[9/28] Restoring PROJECT-LEVEL .claude directories...\" \"FAST\"\n\n$projectClaudeDir = \"$BackupPath\\project-claude\"\nif (Test-Path $projectClaudeDir) {\n    # Check for INDEX.json (v15.x)\n    $indexFile = \"$projectClaudeDir\\INDEX.json\"\n    if (Test-Path $indexFile) {\n        $projectIndex = Get-Content $indexFile -Raw | ConvertFrom-Json\n        $projectCount = 0\n        foreach ($proj in $projectIndex) {\n            $safeName = ($proj.Path -replace \":\", \"_\" -replace \"\\\\\", \"_\" -replace \"^_+\", \"\")\n            $backupDir = \"$projectClaudeDir\\$safeName\"\n            if (Test-Path $backupDir) {\n                $destPath = $proj.Path\n                if (Restore-FastCopy $backupDir $destPath \"Project: $($proj.Name)\") {\n                    $projectCount++\n                }\n            }\n        }\n        if ($projectCount -gt 0) {\n            Write-Step \"  -> Restored $projectCount project .claude directories\" \"SUCCESS\"\n        }\n    } else {\n        # Legacy: _original_path.txt per directory\n        $projectDirs = Get-ChildItem $projectClaudeDir -Directory -ErrorAction SilentlyContinue\n        $projectCount = 0\n\n        foreach ($proj in $projectDirs) {\n            $mappingFile = Join-Path $proj.FullName \"_original_path.txt\"\n            if (Test-Path $mappingFile) {\n                $originalPath = Get-Content $mappingFile -Raw -ErrorAction SilentlyContinue\n                if ($originalPath) {\n                    $originalPath = $originalPath.Trim()\n                    $claudeSubdir = Join-Path $proj.FullName \".claude\"\n                    if (Test-Path $claudeSubdir) {\n                        $destPath = Join-Path $originalPath \".claude\"\n                        if (Restore-FastCopy $claudeSubdir $destPath \"Project: $($proj.Name)\") {\n                            $projectCount++\n                        }\n                    }\n                }\n            }\n        }\n\n        if ($projectCount -gt 0) {\n            Write-Step \"  -> Restored $projectCount project .claude directories\" \"SUCCESS\"\n        }\n    }\n} else {\n    Write-Step \"  -> No project .claude directories in backup\" \"WARNING\"\n}\n#endregion\n\n#region 10. OPENCODE DATA\nWrite-Step \"[10/28] Restoring OPENCODE data (TURBO)...\" \"FAST\"\n\n$opencodeTasks = @(\n    @{Source=\"$BackupPath\\opencode\\data\"; Destination=\"$HOME_DIR\\.local\\share\\opencode\"; Description=\"OpenCode main data\"; IsFile=$false},\n    @{Source=\"$BackupPath\\opencode\\config\"; Destination=\"$HOME_DIR\\.config\\opencode\"; Description=\"OpenCode config\"; IsFile=$false},\n    @{Source=\"$BackupPath\\opencode\\cache\"; Destination=\"$HOME_DIR\\.cache\\opencode\"; Description=\"OpenCode cache\"; IsFile=$false},\n    @{Source=\"$BackupPath\\opencode\\sisyphus\"; Destination=\"$HOME_DIR\\.sisyphus\"; Description=\".sisyphus\"; IsFile=$false},\n    # v13.x paths\n    @{Source=\"$BackupPath\\opencode\\local-share-opencode\"; Destination=\"$HOME_DIR\\.local\\share\\opencode\"; Description=\"OpenCode data (legacy)\"; IsFile=$false},\n    @{Source=\"$BackupPath\\opencode\\config-opencode\"; Destination=\"$HOME_DIR\\.config\\opencode\"; Description=\"OpenCode config (legacy)\"; IsFile=$false},\n    @{Source=\"$BackupPath\\opencode\\cache-opencode\"; Destination=\"$HOME_DIR\\.cache\\opencode\"; Description=\"OpenCode cache (legacy)\"; IsFile=$false},\n    @{Source=\"$BackupPath\\opencode\\dot-opencode\"; Destination=\"$HOME_DIR\\.opencode\"; Description=\"~/.opencode\"; IsFile=$false},\n    @{Source=\"$BackupPath\\auth\\oh-my-opencode.json\"; Destination=\"$HOME_DIR\\.config\\opencode\\oh-my-opencode.json\"; Description=\"OpenCode OAuth config\"; IsFile=$true}\n)\n\nforeach ($task in $opencodeTasks) {\n    if (Restore-FastCopy $task.Source $task.Destination $task.Description -IsFile:$task.IsFile) {\n        Write-Step \"  -> $($task.Description)\" \"SUCCESS\"\n    }\n}\n#endregion\n\n#region 11. APPDATA CLAUDE LOCATIONS\nWrite-Step \"[11/28] Restoring APPDATA Claude locations (TURBO)...\" \"FAST\"\n\n$appdataTasks = @(\n    # v15.x paths\n    @{Source=\"$BackupPath\\appdata\\claude-roaming\"; Destination=\"$APPDATA\\Claude\"; Description=\"AppData\\Roaming\\Claude\"; IsFile=$false},\n    @{Source=\"$BackupPath\\appdata\\claude-local\"; Destination=\"$LOCALAPPDATA\\Claude\"; Description=\"AppData\\Local\\Claude\"; IsFile=$false},\n    # v13.x paths\n    @{Source=\"$BackupPath\\appdata\\roaming-claude\"; Destination=\"$APPDATA\\Claude\"; Description=\"AppData\\Roaming\\Claude (legacy)\"; IsFile=$false},\n    @{Source=\"$BackupPath\\appdata\\roaming-claude-code\"; Destination=\"$APPDATA\\Claude Code\"; Description=\"AppData\\Roaming\\Claude Code\"; IsFile=$false},\n    @{Source=\"$BackupPath\\appdata\\roaming-anthropic\"; Destination=\"$APPDATA\\Anthropic\"; Description=\"AppData\\Roaming\\Anthropic\"; IsFile=$false},\n    @{Source=\"$BackupPath\\appdata\\local-claude\"; Destination=\"$LOCALAPPDATA\\Claude\"; Description=\"AppData\\Local\\Claude (legacy)\"; IsFile=$false},\n    @{Source=\"$BackupPath\\appdata\\local-anthropic\"; Destination=\"$LOCALAPPDATA\\Anthropic\"; Description=\"AppData\\Local\\Anthropic\"; IsFile=$false},\n    @{Source=\"$BackupPath\\appdata\\electron-local\"; Destination=\"$LOCALAPPDATA\\anthropic-ai\\claude-code\"; Description=\"Electron local\"; IsFile=$false},\n    @{Source=\"$BackupPath\\appdata\\electron-roaming\"; Destination=\"$APPDATA\\anthropic-ai\\claude-code\"; Description=\"Electron roaming\"; IsFile=$false},\n    @{Source=\"$BackupPath\\appdata\\claude-desktop-local\"; Destination=\"$LOCALAPPDATA\\Claude Desktop\"; Description=\"Claude Desktop local\"; IsFile=$false},\n    @{Source=\"$BackupPath\\appdata\\claude-desktop-roaming\"; Destination=\"$APPDATA\\Claude Desktop\"; Description=\"Claude Desktop roaming\"; IsFile=$false},\n    @{Source=\"$BackupPath\\appdata\\claude-code-sessions\"; Destination=\"$APPDATA\\Claude\\claude-code-sessions\"; Description=\"claude-code-sessions\"; IsFile=$false}\n)\n\nforeach ($task in $appdataTasks) {\n    if (Restore-FastCopy $task.Source $task.Destination $task.Description -IsFile:$task.IsFile) {\n        Write-Step \"  -> $($task.Description)\" \"SUCCESS\"\n    }\n}\n#endregion\n\n#region 12. CLAWDBOT - WORKSPACE & CONFIG (NEW!)\nWrite-Step \"[12/28] Restoring CLAWDBOT workspace & config...\" \"FAST\"\n\n$clawdbotTasks = @(\n    # Workspace (most important!)\n    @{Source=\"$BackupPath\\clawdbot\\workspace\"; Destination=\"$HOME_DIR\\clawd\"; Description=\"Clawdbot workspace (~/clawd)\"; IsFile=$false},\n    # Dot config directories\n    @{Source=\"$BackupPath\\clawdbot\\dot-clawdbot\"; Destination=\"$HOME_DIR\\.clawdbot\"; Description=\"~/.clawdbot\"; IsFile=$false},\n    @{Source=\"$BackupPath\\clawdbot\\config\"; Destination=\"$HOME_DIR\\.config\\clawdbot\"; Description=\"~/.config/clawdbot\"; IsFile=$false},\n    # AppData locations\n    @{Source=\"$BackupPath\\clawdbot\\appdata-roaming\"; Destination=\"$APPDATA\\clawdbot\"; Description=\"AppData\\Roaming\\clawdbot\"; IsFile=$false},\n    @{Source=\"$BackupPath\\clawdbot\\appdata-local\"; Destination=\"$LOCALAPPDATA\\clawdbot\"; Description=\"AppData\\Local\\clawdbot\"; IsFile=$false},\n    @{Source=\"$BackupPath\\clawdbot\\local-share\"; Destination=\"$HOME_DIR\\.local\\share\\clawdbot\"; Description=\"~/.local/share/clawdbot\"; IsFile=$false},\n    @{Source=\"$BackupPath\\clawdbot\\cache\"; Destination=\"$HOME_DIR\\.cache\\clawdbot\"; Description=\"~/.cache/clawdbot\"; IsFile=$false}\n)\n\nforeach ($task in $clawdbotTasks) {\n    if (Restore-FastCopy $task.Source $task.Destination $task.Description -IsFile:$task.IsFile) {\n        Write-Step \"  -> $($task.Description)\" \"SUCCESS\"\n    }\n}\n\n# Clawdbot config files (individual)\n$clawdbotConfigs = @(\n    @{Source=\"$BackupPath\\clawdbot\\config-files\\clawdbot.yaml\"; Destination=\"$HOME_DIR\\.clawdbot.yaml\"; Description=\"~/.clawdbot.yaml\"; IsFile=$true},\n    @{Source=\"$BackupPath\\clawdbot\\config-files\\clawdbot.json\"; Destination=\"$HOME_DIR\\.clawdbot.json\"; Description=\"~/.clawdbot.json\"; IsFile=$true},\n    @{Source=\"$BackupPath\\clawdbot\\config-files\\clawdbot-home.yaml\"; Destination=\"$HOME_DIR\\clawdbot.yaml\"; Description=\"~/clawdbot.yaml\"; IsFile=$true},\n    @{Source=\"$BackupPath\\clawdbot\\config-files\\clawdbot-home.json\"; Destination=\"$HOME_DIR\\clawdbot.json\"; Description=\"~/clawdbot.json\"; IsFile=$true},\n    @{Source=\"$BackupPath\\clawdbot\\config-files\\workspace-clawdbot.yaml\"; Destination=\"$HOME_DIR\\clawd\\clawdbot.yaml\"; Description=\"~/clawd/clawdbot.yaml\"; IsFile=$true},\n    @{Source=\"$BackupPath\\clawdbot\\config-files\\appdata-config.yaml\"; Destination=\"$APPDATA\\clawdbot\\config.yaml\"; Description=\"AppData config.yaml\"; IsFile=$true},\n    @{Source=\"$BackupPath\\clawdbot\\config-files\\appdata-config.json\"; Destination=\"$APPDATA\\clawdbot\\config.json\"; Description=\"AppData config.json\"; IsFile=$true}\n)\n\nforeach ($task in $clawdbotConfigs) {\n    if (Restore-FastCopy $task.Source $task.Destination $task.Description -IsFile:$task.IsFile) {\n        Write-Step \"  -> $($task.Description)\" \"SUCCESS\"\n    }\n}\n#endregion\n\n#region 13. CLAWDBOT - MEMORY FILES (NEW!)\nWrite-Step \"[13/28] Restoring CLAWDBOT memory files...\" \"FAST\"\n\n$clawdbotMemory = @(\n    @{Source=\"$BackupPath\\clawdbot\\memory\\MEMORY.md\"; Destination=\"$HOME_DIR\\clawd\\MEMORY.md\"; Description=\"MEMORY.md\"; IsFile=$true},\n    @{Source=\"$BackupPath\\clawdbot\\memory\\AGENTS.md\"; Destination=\"$HOME_DIR\\clawd\\AGENTS.md\"; Description=\"AGENTS.md\"; IsFile=$true},\n    @{Source=\"$BackupPath\\clawdbot\\memory\\SOUL.md\"; Destination=\"$HOME_DIR\\clawd\\SOUL.md\"; Description=\"SOUL.md\"; IsFile=$true},\n    @{Source=\"$BackupPath\\clawdbot\\memory\\TOOLS.md\"; Destination=\"$HOME_DIR\\clawd\\TOOLS.md\"; Description=\"TOOLS.md\"; IsFile=$true},\n    @{Source=\"$BackupPath\\clawdbot\\memory\\IDENTITY.md\"; Destination=\"$HOME_DIR\\clawd\\IDENTITY.md\"; Description=\"IDENTITY.md\"; IsFile=$true},\n    @{Source=\"$BackupPath\\clawdbot\\memory\\USER.md\"; Destination=\"$HOME_DIR\\clawd\\USER.md\"; Description=\"USER.md\"; IsFile=$true},\n    @{Source=\"$BackupPath\\clawdbot\\memory\\HEARTBEAT.md\"; Destination=\"$HOME_DIR\\clawd\\HEARTBEAT.md\"; Description=\"HEARTBEAT.md\"; IsFile=$true},\n    @{Source=\"$BackupPath\\clawdbot\\memory\\daily\"; Destination=\"$HOME_DIR\\clawd\\memory\"; Description=\"Daily memory logs\"; IsFile=$false}\n)\n\nforeach ($task in $clawdbotMemory) {\n    if (Restore-FastCopy $task.Source $task.Destination $task.Description -IsFile:$task.IsFile) {\n        Write-Step \"  -> $($task.Description)\" \"SUCCESS\"\n    }\n}\n#endregion\n\n#region 14. CLAWDBOT - FOUND DIRECTORIES (NEW!)\nWrite-Step \"[14/28] Restoring CLAWDBOT directories from all drives...\" \"FAST\"\n\n$clawdbotFoundDir = \"$BackupPath\\clawdbot-found\"\nif (Test-Path $clawdbotFoundDir) {\n    $indexFile = \"$clawdbotFoundDir\\INDEX.json\"\n    if (Test-Path $indexFile) {\n        $clawdbotIndex = Get-Content $indexFile -Raw | ConvertFrom-Json\n        $cbCount = 0\n        foreach ($cb in $clawdbotIndex) {\n            $safeName = ($cb.Path -replace \":\", \"_\" -replace \"\\\\\", \"_\" -replace \"^_+\", \"\")\n            $backupDir = \"$clawdbotFoundDir\\$safeName\"\n            if (Test-Path $backupDir) {\n                # Create parent directory if needed\n                $parentDir = Split-Path $cb.Path -Parent\n                if ($parentDir -and -not (Test-Path $parentDir)) {\n                    New-Item -ItemType Directory -Path $parentDir -Force -ErrorAction SilentlyContinue | Out-Null\n                }\n                if (Restore-FastCopy $backupDir $cb.Path \"Clawdbot: $($cb.Name)\") {\n                    $cbCount++\n                }\n            }\n        }\n        if ($cbCount -gt 0) {\n            Write-Step \"  -> Restored $cbCount clawdbot directories from all drives\" \"SUCCESS\"\n        }\n    }\n} else {\n    Write-Step \"  -> No additional clawdbot directories in backup\" \"INFO\"\n}\n#endregion\n\n#region 15. VS CODE CLAUDE EXTENSIONS\nWrite-Step \"[15/28] Restoring VS CODE Claude extensions settings...\" \"FAST\"\n\n$vscodeTasks = @(\n    @{Source=\"$BackupPath\\ide\\vscode\"; Destination=\"$APPDATA\\Code\\User\"; Description=\"VS Code User\"; IsFile=$false},\n    @{Source=\"$BackupPath\\ide\\vscode-ext\"; Destination=\"$HOME_DIR\\.vscode\\extensions\"; Description=\"VS Code extensions\"; IsFile=$false},\n    # v13.x paths\n    @{Source=\"$BackupPath\\vscode\\User\"; Destination=\"$APPDATA\\Code\\User\"; Description=\"VS Code User (legacy)\"; IsFile=$false}\n)\n\nforeach ($task in $vscodeTasks) {\n    if (Restore-FastCopy $task.Source $task.Destination $task.Description -IsFile:$task.IsFile) {\n        Write-Step \"  -> $($task.Description)\" \"SUCCESS\"\n    }\n}\n\n# Legacy: per-profile\nforeach ($profile in @(\"User\", \"Insiders\")) {\n    $backupVsc = \"$BackupPath\\vscode\\$profile\"\n    if (Test-Path $backupVsc) {\n        $destPath = if ($profile -eq \"User\") { \"$APPDATA\\Code\\User\" } else { \"$APPDATA\\Code - Insiders\\User\" }\n        if (Restore-FastCopy $backupVsc $destPath \"VS Code: $profile\") {\n            Write-Step \"  -> VS Code: $profile\" \"SUCCESS\"\n        }\n    }\n}\n\n# Claude-specific extensions (legacy)\n$backupExtensions = \"$BackupPath\\vscode\\extensions\"\nif (Test-Path $backupExtensions) {\n    $vscExtensions = \"$HOME_DIR\\.vscode\\extensions\"\n    $claudeExtensions = Get-ChildItem $backupExtensions -Directory -ErrorAction SilentlyContinue |\n                        Where-Object { $_.Name -match \"claude|anthropic|cline|continue|copilot\" }\n    foreach ($ext in $claudeExtensions) {\n        $destExt = \"$vscExtensions\\$($ext.Name)\"\n        if (Restore-FastCopy $ext.FullName $destExt \"VS Code ext: $($ext.Name)\") {\n            Write-Step \"  -> Extension: $($ext.Name)\" \"SUCCESS\"\n        }\n    }\n}\n#endregion\n\n#region 16. CURSOR IDE SETTINGS\nWrite-Step \"[16/28] Restoring CURSOR IDE settings...\" \"FAST\"\n\n$cursorPaths = @(\n    @{Backup=\"$BackupPath\\ide\\cursor\"; Dest=\"$APPDATA\\Cursor\\User\"; Desc=\"Cursor User settings\"},\n    @{Backup=\"$BackupPath\\ide\\cursor-home\"; Dest=\"$HOME_DIR\\.cursor\"; Desc=\"Cursor home\"},\n    @{Backup=\"$BackupPath\\cursor\\user\"; Dest=\"$APPDATA\\Cursor\\User\"; Desc=\"Cursor User (legacy)\"},\n    @{Backup=\"$BackupPath\\cursor\\extensions\"; Dest=\"$HOME_DIR\\.cursor\\extensions\"; Desc=\"Cursor extensions\"},\n    @{Backup=\"$BackupPath\\cursor\\local\"; Dest=\"$LOCALAPPDATA\\Cursor\"; Desc=\"Cursor local data\"}\n)\n\nforeach ($cursor in $cursorPaths) {\n    if (Test-Path $cursor.Backup) {\n        if (Restore-FastCopy $cursor.Backup $cursor.Dest $cursor.Desc) {\n            Write-Step \"  -> $($cursor.Desc)\" \"SUCCESS\"\n        }\n    }\n}\n#endregion\n\n#region 17. WINDSURF SETTINGS\nWrite-Step \"[17/28] Restoring WINDSURF settings...\" \"FAST\"\n\n$windsurfPaths = @(\n    @{Backup=\"$BackupPath\\ide\\windsurf\"; Dest=\"$APPDATA\\Windsurf\\User\"; Desc=\"Windsurf User settings\"},\n    @{Backup=\"$BackupPath\\windsurf\\user\"; Dest=\"$APPDATA\\Windsurf\\User\"; Desc=\"Windsurf User (legacy)\"},\n    @{Backup=\"$BackupPath\\windsurf\\extensions\"; Dest=\"$HOME_DIR\\.windsurf\\extensions\"; Desc=\"Windsurf extensions\"},\n    @{Backup=\"$BackupPath\\windsurf\\local\"; Dest=\"$LOCALAPPDATA\\Windsurf\"; Desc=\"Windsurf local data\"}\n)\n\nforeach ($ws in $windsurfPaths) {\n    if (Test-Path $ws.Backup) {\n        if (Restore-FastCopy $ws.Backup $ws.Dest $ws.Desc) {\n            Write-Step \"  -> $($ws.Desc)\" \"SUCCESS\"\n        }\n    }\n}\n#endregion\n\n#region 18. BROWSER EXTENSION DATA\nWrite-Step \"[18/28] Restoring BROWSER extension data (Chrome/Edge)...\" \"FAST\"\n\n$chromeExtPath = \"$LOCALAPPDATA\\Google\\Chrome\\User Data\\Default\\Extensions\"\n$chromeSyncPath = \"$LOCALAPPDATA\\Google\\Chrome\\User Data\\Default\\Sync Extension Settings\"\n$edgeExtPath = \"$LOCALAPPDATA\\Microsoft\\Edge\\User Data\\Default\\Extensions\"\n$edgeSyncPath = \"$LOCALAPPDATA\\Microsoft\\Edge\\User Data\\Default\\Sync Extension Settings\"\n\n$browserTasks = @(\n    @{Source=\"$BackupPath\\browser\\chrome\"; Dest=$chromeExtPath; Desc=\"Chrome extensions\"},\n    @{Source=\"$BackupPath\\browser\\edge\"; Dest=$edgeExtPath; Desc=\"Edge extensions\"},\n    @{Source=\"$BackupPath\\browser\\chrome-extensions\"; Dest=$chromeExtPath; Desc=\"Chrome extensions (legacy)\"},\n    @{Source=\"$BackupPath\\browser\\chrome-sync-settings\"; Dest=$chromeSyncPath; Desc=\"Chrome sync settings\"},\n    @{Source=\"$BackupPath\\browser\\edge-extensions\"; Dest=$edgeExtPath; Desc=\"Edge extensions (legacy)\"},\n    @{Source=\"$BackupPath\\browser\\edge-sync-settings\"; Dest=$edgeSyncPath; Desc=\"Edge sync settings\"}\n)\n\nforeach ($task in $browserTasks) {\n    if (Test-Path $task.Source) {\n        if (Restore-FastCopy $task.Source $task.Dest $task.Desc) {\n            Write-Step \"  -> $($task.Desc)\" \"SUCCESS\"\n        }\n    }\n}\n#endregion\n\n#region 19. MCP CONFIGURATION\nWrite-Step \"[19/28] Restoring MCP configuration...\" \"FAST\"\n\n$mcpTasks = @(\n    @{Source=\"$BackupPath\\mcp\\desktop-config.json\"; Destination=\"$APPDATA\\Claude\\claude_desktop_config.json\"; Description=\"MCP desktop config\"; IsFile=$true},\n    @{Source=\"$BackupPath\\mcp\\claude_desktop_config.json\"; Destination=\"$APPDATA\\Claude\\claude_desktop_config.json\"; Description=\"MCP desktop config (legacy)\"; IsFile=$true},\n    @{Source=\"$BackupPath\\mcp\\claudecode-home\"; Destination=\"$HOME_DIR\\claudecode\"; Description=\"~/claudecode\"; IsFile=$false},\n    @{Source=\"$BackupPath\\mcp\\claudecode-dot\"; Destination=\"$HOME_DIR\\.claudecode\"; Description=\"~/.claudecode\"; IsFile=$false}\n)\n\nforeach ($task in $mcpTasks) {\n    if (Restore-FastCopy $task.Source $task.Destination $task.Description -IsFile:$task.IsFile) {\n        Write-Step \"  -> $($task.Description)\" \"SUCCESS\"\n    }\n}\n\n# MCP wrapper scripts\nforeach ($wrapperPath in @(\"$BackupPath\\mcp\\wrappers\", \"$BackupPath\\claude-files\\mcp\")) {\n    if (Test-Path $wrapperPath) {\n        Get-ChildItem $wrapperPath -File -ErrorAction SilentlyContinue | ForEach-Object {\n            if (Restore-FastCopy $_.FullName \"$HOME_DIR\\$($_.Name)\" \"MCP wrapper: $($_.Name)\" -IsFile) {\n                Write-Step \"  -> MCP: $($_.Name)\" \"SUCCESS\"\n            }\n        }\n    }\n}\n\nif (Test-Path \"$BackupPath\\mcp\\claude-wrappers\") {\n    $claudeMcpDir = \"$HOME_DIR\\.claude\"\n    if (-not (Test-Path $claudeMcpDir)) {\n        New-Item -ItemType Directory -Path $claudeMcpDir -Force | Out-Null\n    }\n    Get-ChildItem \"$BackupPath\\mcp\\claude-wrappers\" -File -ErrorAction SilentlyContinue | ForEach-Object {\n        if (Restore-FastCopy $_.FullName \"$claudeMcpDir\\$($_.Name)\" \"MCP (.claude): $($_.Name)\" -IsFile) {\n            Write-Step \"  -> MCP (.claude): $($_.Name)\" \"SUCCESS\"\n        }\n    }\n}\n#endregion\n\n#region 20. SETTINGS & CONFIGURATION\nWrite-Step \"[20/28] Restoring SETTINGS & CONFIG...\" \"FAST\"\n\n$settingsTasks = @(\n    @{Source=\"$BackupPath\\settings\\settings.json\"; Destination=\"$HOME_DIR\\.claude\\settings.json\"; Description=\"Claude settings.json\"; IsFile=$true},\n    @{Source=\"$BackupPath\\settings\\settings.local.json\"; Destination=\"$HOME_DIR\\.claude\\settings.local.json\"; Description=\"Claude settings.local.json\"; IsFile=$true},\n    @{Source=\"$BackupPath\\settings\\config-claude\"; Destination=\"$HOME_DIR\\.config\\claude\"; Description=\".config/claude\"; IsFile=$false}\n)\n\nforeach ($task in $settingsTasks) {\n    if (Restore-FastCopy $task.Source $task.Destination $task.Description -IsFile:$task.IsFile) {\n        Write-Step \"  -> $($task.Description)\" \"SUCCESS\"\n    }\n}\n#endregion\n\n#region 21. AGENTS & SKILLS\nWrite-Step \"[21/28] Restoring AGENTS & SKILLS...\" \"FAST\"\n\n$agentTasks = @(\n    @{Source=\"$BackupPath\\agents\\claude-agents\"; Destination=\"$HOME_DIR\\.claude\\agents\"; Description=\".claude/agents\"; IsFile=$false},\n    @{Source=\"$BackupPath\\agents\\claude-skills\"; Destination=\"$HOME_DIR\\.claude\\skills\"; Description=\".claude/skills\"; IsFile=$false},\n    @{Source=\"$BackupPath\\agents\\claude-commands\"; Destination=\"$HOME_DIR\\.claude\\commands\"; Description=\".claude/commands\"; IsFile=$false},\n    @{Source=\"$BackupPath\\agents\\CLAUDE.md\"; Destination=\"$HOME_DIR\\CLAUDE.md\"; Description=\"~/CLAUDE.md\"; IsFile=$true},\n    @{Source=\"$BackupPath\\agents\\AGENTS.md\"; Destination=\"$HOME_DIR\\AGENTS.md\"; Description=\"~/AGENTS.md\"; IsFile=$true}\n)\n\nforeach ($task in $agentTasks) {\n    if (Restore-FastCopy $task.Source $task.Destination $task.Description -IsFile:$task.IsFile) {\n        Write-Step \"  -> $($task.Description)\" \"SUCCESS\"\n    }\n}\n#endregion\n\n#region 22. NPM GLOBAL MODULES\nWrite-Step \"[22/28] Restoring NPM global modules...\" \"FAST\"\n\n$npmPrefix = npm config get prefix 2>$null\nif ($npmPrefix) {\n    if (Test-Path \"$BackupPath\\npm\\node_modules\") {\n        if (Restore-FastCopy \"$BackupPath\\npm\\node_modules\" \"$npmPrefix\\node_modules\" \"npm global node_modules\") {\n            Write-Step \"  -> npm node_modules restored\" \"SUCCESS\"\n        }\n    }\n}\n\nif (Restore-FastCopy \"$BackupPath\\npm\\npmrc\" \"$HOME_DIR\\.npmrc\" \".npmrc\" -IsFile) {\n    Write-Step \"  -> .npmrc\" \"SUCCESS\"\n}\n#endregion\n\n#region 23. BUN PACKAGE MANAGER (NEW!)\nWrite-Step \"[23/28] Restoring BUN package manager...\" \"FAST\"\n\n$bunTasks = @(\n    @{Source=\"$BackupPath\\bun\\dot-bun\"; Destination=\"$HOME_DIR\\.bun\"; Description=\"~/.bun\"; IsFile=$false},\n    @{Source=\"$BackupPath\\bun\\local\"; Destination=\"$LOCALAPPDATA\\bun\"; Description=\"LocalAppData\\bun\"; IsFile=$false}\n)\n\nforeach ($task in $bunTasks) {\n    if (Restore-FastCopy $task.Source $task.Destination $task.Description -IsFile:$task.IsFile) {\n        Write-Step \"  -> $($task.Description)\" \"SUCCESS\"\n    }\n}\n\n# Add bun to PATH if needed\n$bunBinPath = \"$HOME_DIR\\.bun\\bin\"\nif (Test-Path $bunBinPath) {\n    $userPath = [Environment]::GetEnvironmentVariable(\"Path\", \"User\")\n    if ($userPath -notmatch [regex]::Escape($bunBinPath)) {\n        Write-Step \"  -> Adding .bun\\bin to PATH...\" \"INSTALL\"\n        $newPath = \"$bunBinPath;$userPath\"\n        [Environment]::SetEnvironmentVariable(\"Path\", $newPath, \"User\")\n        $env:Path = \"$bunBinPath;$env:Path\"\n        Write-Step \"  -> PATH updated with .bun\\bin\" \"SUCCESS\"\n    }\n}\n#endregion\n\n#region 24. PYTHON & UV (NEW!)\nWrite-Step \"[24/28] Restoring PYTHON & UV...\" \"FAST\"\n\n$pythonTasks = @(\n    @{Source=\"$BackupPath\\python\\uv-data\"; Destination=\"$HOME_DIR\\.local\\share\\uv\"; Description=\"UV data\"; IsFile=$false},\n    @{Source=\"$BackupPath\\python\\uv-local\"; Destination=\"$LOCALAPPDATA\\uv\"; Description=\"UV local\